NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/tradecircle?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret-at-least-16-chars
PORT=5000
CORS_ORIGIN=http://localhost:5000

# Optional: bootstrap an admin account on startup
# ADMIN_EMAIL=admin@tradecircle.com
# ADMIN_PASSWORD=StrongAdminPassword123
# ADMIN_NAME=TradeCircle Admin

# Optional: allow admin self-registration with secret (disabled by default)
# ALLOW_ADMIN_REGISTRATION=false
# ADMIN_REGISTER_SECRET=replace-with-secure-admin-secret

# Optional: allow admin role promotions from admin dashboard API (disabled by default)
# ALLOW_ADMIN_PROMOTION=false

# Optional moderation tuning
# REPORT_THRESHOLD=3
# REPORT_PENALTY=10

# Optional: simulated payment endpoint (disabled by default to align with first-phase scope)
# ENABLE_SIMULATED_PAYMENTS=false

# Optional: escrow fee percentage for TradeCircle Secure Hold
# ESCROW_FEE_PERCENT=2

# Optional: configure persistent uploads directory (Render disk mount e.g. /var/data/uploads)
# UPLOADS_DIR=uploads
